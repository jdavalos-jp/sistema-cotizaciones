# Backend Environment Variables
# IMPORTANTE: Este es un template. Copia esto a .env y completa con valores reales
# NUNCA comitees .env al repositorio

DATABASE_URL=postgresql://tu_user:tu_password@host:5432/tu_db
# Opcional: usa DIRECT_URL si tu proveedor separa URL de migraciones y URL pooled.
DIRECT_URL=postgresql://tu_user:tu_password@host:5432/tu_db
# Para Vercel serverless usa 1 o 2. Para Railway/servidor persistente puedes usar 10.
DB_POOL_MAX=1
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# Supabase Storage/API, no es la URL de Postgres.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

NODE_ENV=development
PORT=3001

# JWT Configuration
# CRITICAL: Set a strong JWT secret - don't use the default!
JWT_SECRET=tu_secret_muy_seguro_aqui_cambiar_en_produccion
JWT_EXPIRY=7d

# CORS - comma-separated list of allowed origins
# Development: http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Opcional para PDFs
COMPANY_NAME=JDB LAB
# COMPANY_LOGO_PATH=/app/assets/logojdblab.jpeg

