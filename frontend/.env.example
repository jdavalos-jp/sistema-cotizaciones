# API Configuration
# Set to your backend API URL (default: /api, which is proxied by Vite during development)
VITE_API_BASE_URL=/api

# For production, set this to your backend's full URL
# VITE_API_BASE_URL=https://api.example.com

# Required only if you import/use frontend Supabase client directly.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
